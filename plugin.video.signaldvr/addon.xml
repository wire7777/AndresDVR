<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.signaldvr"
       name="SignalDVR"
       version="0.1.4"
       provider-name="wire7777">

    <requires>
        <import addon="xbmc.python" version="3.0.0"/>
    </requires>

    <extension point="xbmc.python.pluginsource"
               library="default.py">
        <provides>video</provides>
    </extension>

    <extension point="xbmc.addon.metadata">
        <summary lang="en_GB">SignalDVR Client</summary>
        <description lang="en_GB">Browse and play SignalDVR live TV and recordings.</description>
        <disclaimer lang="en_GB">Requires a running SignalDVR server on your network.</disclaimer>
        <platform>all</platform>
        <license>GPL-2.0-only</license>
        <forum/>
        <website/>
        <source/>
        <email/>
        <news>
v0.1.4 - Bug fixes and stability improvements
v0.1.3 - Added recordings support
v0.1.2 - Live TV improvements
v0.1.1 - Initial release
        </news>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
            <clearlogo>logo.png</clearlogo>
        </assets>
    </extension>

</addon>