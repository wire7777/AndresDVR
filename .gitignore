# ===========================
# Python
# ===========================
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.venv/
venv/

# ===========================
# Editors / OS
# ===========================
.vscode/
.DS_Store
Thumbs.db

# ===========================
# Database
# ===========================
database/*.db
database/*.db-*
*.sqlite
*.sqlite3
*.db-journal
*.sqlite-journal

